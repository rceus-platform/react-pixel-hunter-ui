{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Vite: Dev",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/application-source",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev",
                "--",
                "--host"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Chrome: Debug",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/application-source/src"
        }
    ]
}